# Copy to .env.local and fill in.
# Values come from Supabase project settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only. NEVER expose to the browser. Used by the cron worker to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Anthropic API key for the verdict generator (Claude Haiku 4.5).
# Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY

# Resend (email channel). https://resend.com/api-keys
# For testing, EMAIL_FROM can be omitted — defaults to "onboarding@resend.dev"
# (which can only deliver to the email tied to your Resend account). For real
# use, verify a domain in Resend and put a from address on it here.
RESEND_API_KEY=re_YOUR-RESEND-KEY
# EMAIL_FROM=bike-my-day <noreply@yourdomain.com>

# Shared secret for the hourly cron at /api/cron/notify. Vercel sends this
# automatically as Authorization: Bearer <CRON_SECRET>. Generate with:
#   openssl rand -hex 32
# Set the same value in your Vercel project's environment variables.
CRON_SECRET=YOUR-RANDOM-SECRET
