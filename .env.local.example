# Copy to .env.local and fill in.
# Values come from Supabase project settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only. NEVER expose to the browser. Used by the cron worker to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Anthropic API key for the verdict generator (Claude Haiku 4.5).
# Get one at https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-KEY

# Added in later steps:
# RESEND_API_KEY=
# CRON_SECRET=
